#!/usr/bin/env bash
# spawn-claude — launch a hands-off Claude Code workstream in a new zellij tab,
# in its OWN git worktree by default, so parallel claudes never fight over a
# working tree / branch.
#
# Usage:
#   spawn-claude [options] <name> <repo-dir> <prompt...>
#
# Options (must precede the positional args):
#   --here              run in <repo-dir> itself, no worktree (the old behaviour)
#   --base <ref>        branch the worktree off <ref> (default: origin/main, else
#                       local main/master, else current HEAD)
#   --setup <cmd>       run <cmd> in the pane before claude (e.g. "pnpm install") —
#                       a fresh worktree has no node_modules
#   --warm-from <dir>   copy node_modules subtrees from <dir> into the worktree before
#                       running --setup. Warm-copies every node_modules dir found at the
#                       top two levels of <dir> so pnpm/npm installs are near-instant.
#                       Pair with --setup "pnpm install --frozen-lockfile --prefer-offline".
#   --model <ref>       model for the spawned session (default: sonnet). Spawned
#                       workers default to Sonnet — these tabs do bounded, well-specified
#                       work where Sonnet is the right tool ("Sonnet builds"). Override
#                       per-call with --model opus, or globally with the MODEL env var.
#
# Default: makes a worktree at <repo-parent>/<repo>.wt/<name> on a new branch
# wt/<name>, OUTSIDE the repo tree (so whole-tree commands don't walk it), then
# runs `claude --dangerously-skip-permissions --model sonnet "<prompt>"` there in a
# new, named zellij tab. Only ever CREATES a zellij tab (never closes one).
#
# Windows notes: native zellij execs bare "bash" off the Windows PATH, where the
# WSL launcher (C:\Windows\System32\bash.exe) wins — so we pin THIS shell's
# Git-bash absolute path. All paths are cygpath -m'd; the prompt rides in a temp
# file so no shell/KDL quoting can mangle it.
set -euo pipefail

here=0; base=""; setup=""; warm_from=""; dry=0; model="${MODEL:-sonnet}"
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --here) here=1; shift;;
    --base) base="${2:?--base needs a ref}"; shift 2;;
    --setup) setup="${2:?--setup needs a command}"; shift 2;;
    --warm-from) warm_from="${2:?--warm-from needs a dir}"; shift 2;;
    --model) model="${2:?--model needs a ref}"; shift 2;;
    --dry-run) dry=1; shift;;
    --) shift; break;;
    *) echo "spawn-claude: unknown option $1" >&2; exit 2;;
  esac
done

if [[ $# -lt 3 ]]; then
  echo "usage: spawn-claude [--here] [--base <ref>] [--setup <cmd>] <name> <repo-dir> <prompt...>" >&2
  exit 2
fi
name="$1"; repo="$2"; shift 2; prompt="$*"

command -v zellij >/dev/null || { echo "spawn-claude: zellij not found" >&2; exit 1; }
command -v claude >/dev/null || { echo "spawn-claude: claude not found" >&2; exit 1; }
[[ -n "${ZELLIJ:-}" ]] || { echo "spawn-claude: not inside a zellij session" >&2; exit 1; }
[[ -d "$repo" ]] || { echo "spawn-claude: repo dir not found: $repo" >&2; exit 1; }

# cygpath -m gives drive + forward slashes: a valid Windows path that is also
# KDL-safe (backslashes are escape chars in KDL strings). No-op off Windows.
to_native() { command -v cygpath >/dev/null && cygpath -m "$1" || printf '%s' "$1"; }
bash_native=$(to_native "$(command -v bash)")

# slug for branch + dir names
slug=$(printf '%s' "$name" | tr -c 'A-Za-z0-9._-' '-' | sed 's/--*/-/g; s/^-//; s/-$//')
[[ -n "$slug" ]] || slug="claude"

if [[ $here -eq 1 ]]; then
  workdir="$repo"
else
  git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || { echo "spawn-claude: $repo is not a git repo (use --here to run there directly)" >&2; exit 1; }

  if [[ -z "$base" ]]; then
    if   git -C "$repo" show-ref -q --verify refs/heads/main;   then base=main
    elif git -C "$repo" show-ref -q --verify refs/heads/master; then base=master
    else base=$(git -C "$repo" rev-parse --abbrev-ref HEAD); fi
  fi
  [[ $dry -eq 0 ]] && { git -C "$repo" fetch -q origin "$base" 2>/dev/null || true; }
  start="$base"
  git -C "$repo" show-ref -q --verify "refs/remotes/origin/$base" && start="origin/$base"

  repo_abs=$(cd "$repo" && pwd)
  parent=$(dirname "$repo_abs"); bn=$(basename "$repo_abs")
  branch="wt/$slug"; workdir="$parent/$bn.wt/$slug"
  if git -C "$repo" show-ref -q --verify "refs/heads/$branch" || [[ -e "$workdir" ]]; then
    sfx=$(date +%H%M%S); branch="wt/$slug-$sfx"; workdir="$parent/$bn.wt/$slug-$sfx"
  fi

  if [[ $dry -eq 1 ]]; then
    echo "[dry-run] git -C $repo worktree add -b $branch $workdir $start" >&2
  else
    echo "spawn-claude: creating worktree $workdir on $branch (from $start)" >&2
    git -C "$repo" worktree add -b "$branch" "$workdir" "$start" >&2
  fi
fi

# ── Warm node_modules copy ───────────────────────────────────────────────────
# Copy every node_modules dir found at top two levels of --warm-from into the
# equivalent location in the worktree. Saves a full pnpm/npm install — pair
# with --setup "pnpm install --frozen-lockfile --prefer-offline".
if [[ -n "$warm_from" && $here -eq 0 ]]; then
  if [[ $dry -eq 1 ]]; then
    echo "[dry-run] warm-copy node_modules from $warm_from → $workdir" >&2
  else
    echo "spawn-claude: warming node_modules from $warm_from" >&2
    # top-level: <warm_from>/node_modules
    if [[ -d "$warm_from/node_modules" ]]; then
      cp -r "$warm_from/node_modules" "$workdir/node_modules"
    fi
    # one level deep: <warm_from>/*/node_modules
    for sub in "$warm_from"/*/node_modules; do
      [[ -d "$sub" ]] || continue
      rel="${sub#"$warm_from/"}"          # e.g. apps/api/node_modules
      parent_dir="$workdir/$(dirname "$rel")"
      mkdir -p "$parent_dir"
      cp -r "$sub" "$parent_dir/node_modules"
    done
    echo "spawn-claude: warm-copy done" >&2
  fi
fi

workdir_native=$(to_native "$workdir")
# Resolve @- (stdin) and @<file> prompt sources, matching zj-claude.sh behaviour.
spawndir="${TMPDIR:-/tmp}/claude-spawn"
mkdir -p "$spawndir"
find "$spawndir" -type f -mtime +1 -delete 2>/dev/null || true
if [[ "$prompt" == "@-" ]]; then
  promptfile="$(mktemp "$spawndir/$slug-XXXXXX.md")"
  cat > "$promptfile"
elif [[ "$prompt" == @* ]]; then
  promptfile="${prompt:1}"
else
  promptfile="$(mktemp "$spawndir/$slug-XXXXXX.md")"
  printf '%s' "$prompt" > "$promptfile"
fi
pf_native=$(to_native "$promptfile")
pre=""; [[ -n "$setup" ]] && pre="$setup; "

# IMPORTANT: mirror the user's default_tab_template chrome exactly.
# A bare `layout { pane … }` makes a tab with NO tab bar — focus lands there
# on attach and the whole tab strip vanishes from view. The two surrounding
# panes restore chrome. Plugin locations must match default.kdl exactly:
# top = zellaude, bottom = zjstatus (not the stock zellij:tab-bar/status-bar).
layout=$(mktemp --suffix=.kdl)
cat > "$layout" <<KDL
layout {
    pane size=1 borderless=true {
        plugin location="https://github.com/ishefi/zellaude/releases/latest/download/zellaude.wasm"
    }
    pane command="$bash_native" cwd="$workdir_native" {
        args "-lc" "${pre}claude --dangerously-skip-permissions --model $model \"\$(cat '$pf_native')\"; exec \"$bash_native\" -i"
    }
    pane size=1 borderless=true {
        plugin location="file:C:/Users/tajdi/AppData/Roaming/zellij/config/plugins/zjstatus.wasm" {
            format_left   ""
            format_center ""
            format_right  "{datetime}"
            format_space  ""
            mode_normal        "#[bg=#89B4FA,fg=#1E1E2E,bold] NORMAL "
            mode_locked        "#[bg=#F38BA8,fg=#1E1E2E,bold] LOCKED "
            mode_pane          "#[bg=#A6E3A1,fg=#1E1E2E,bold] PANE "
            mode_tab           "#[bg=#A6E3A1,fg=#1E1E2E,bold] TAB "
            mode_scroll        "#[bg=#F9E2AF,fg=#1E1E2E,bold] SCROLL "
            mode_resize        "#[bg=#FAB387,fg=#1E1E2E,bold] RESIZE "
            mode_move          "#[bg=#CBA6F7,fg=#1E1E2E,bold] MOVE "
            mode_search        "#[bg=#F9E2AF,fg=#1E1E2E,bold] SEARCH "
            mode_session       "#[bg=#CBA6F7,fg=#1E1E2E,bold] SESSION "
            mode_tmux          "#[bg=#F5C2E7,fg=#1E1E2E,bold] TMUX "
            mode_renametab     "#[bg=#A6E3A1,fg=#1E1E2E,bold] RENAME TAB "
            mode_renamepane    "#[bg=#A6E3A1,fg=#1E1E2E,bold] RENAME PANE "
            datetime          "#[fg=#6C7086,bold] {format} "
            datetime_format   "%d %b %Y  %H:%M"
            datetime_timezone "Europe/London"
        }
    }
}
KDL

if [[ $dry -eq 1 ]]; then
  echo "[dry-run] zellij action new-tab --name '$name' --layout <generated>" >&2
  echo "[dry-run] --- layout ---" >&2; cat "$layout" >&2
  rm -f "$layout" "$promptfile"
  exit 0
fi

zellij action new-tab --name "$name" --layout "$(to_native "$layout")"
echo "spawn-claude: launched tab '$name' → claude --model $model in $workdir"
rm -f "$layout"
