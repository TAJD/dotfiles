      "Bash(psql:*)",
      "Bash(pg_isready:*)",
      "Bash(pg_ctl:*)",
      "Bash(net start:*)",
      "Bash(sc query:*)",
      "Bash(scoop:*)",
      "Bash(gem:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(ssh-keygen:*)",
      "Bash(actionlint:*)",
      "Bash(gcc:*)",
      "Bash(make:*)",
      "Bash(openssl rand:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
