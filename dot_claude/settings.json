      "Bash(jq:*)",
      "Bash(ast-grep:*)",
      "Bash(sg:*)",
      "Bash(cass:*)",
      "Bash(rtk:*)",
      "Bash(git:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(bd:*)",
      "Bash(bv:*)",
      "Bash(BEADS_NO_DAEMON=1 bd:*)",
      "Bash(mix:*)",
      "Bash(elixir:*)",
